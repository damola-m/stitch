## =============================================================================
## .gitignore — Stitch
## Node.js / TypeScript MCP Server + Visual Studio JavaScript SDK project
## =============================================================================

# -----------------------------------------------------------------------------
# Node / npm
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
.pnpm-store/

# Lock files — keep package-lock.json tracked; ignore others if not using them
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# TypeScript build output
# -----------------------------------------------------------------------------
stitch/build/
stitch/dist/
*.js.map
*.d.ts.map

# -----------------------------------------------------------------------------
# Environment & secrets — NEVER commit API keys
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# Keep the example file tracked so new contributors know what vars are needed
!.env.example

# -----------------------------------------------------------------------------
# Visual Studio working data
# -----------------------------------------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# -----------------------------------------------------------------------------
# OS-generated junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?
*~
*.bak
*.tmp

# -----------------------------------------------------------------------------
# Editor / tooling caches
# -----------------------------------------------------------------------------
.vscode/
.idea/
.eslintcache
.turbo/
.cache/

# -----------------------------------------------------------------------------
# Test & coverage output
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
